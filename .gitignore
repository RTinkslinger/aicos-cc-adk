# AI CoS Git Ignore
# This repo is LOCAL ONLY (no remote) — used for branching/worktrees in parallel dev

# Separate git repo — has its own remote on GitHub
aicos-digests/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
venv/
.venv/

# Node (if any scripts use it)
node_modules/

# Environment & secrets
.env
.env.*
*.key
*.pem

# OS files
.DS_Store
Thumbs.db
._*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Large files / media
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv

# Temporary / build artifacts
/tmp/
*.tmp
*.bak
*.log

# Claude Code — ignore local config, track shared infrastructure (sync + hooks)
.claude/*
!.claude/sync/
!.claude/hooks/
!.claude/sequential-files.txt
.claude/sync/.last-push

# Build Roadmap — ephemeral working copy (Notion is source of truth)
ROADMAP.md
.claude/worktrees/
.env.local
