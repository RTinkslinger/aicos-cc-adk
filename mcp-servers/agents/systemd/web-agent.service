[Unit]
Description=AI CoS Web Agent
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/agents
EnvironmentFile=-/opt/agents/.env
ExecStart=/opt/agents/.venv/bin/python3 -m web.server
Restart=always
RestartSec=5
MemoryMax=1G
ExecStopPost=/usr/bin/pkill -f chrome
StandardOutput=append:/opt/agents/logs/web.log
StandardError=append:/opt/agents/logs/web.log

[Install]
WantedBy=multi-user.target
