#!/bin/bash
# yt — Trigger AI CoS content pipeline on the droplet via SSH
#
# Usage:
#   yt                    → Run pipeline (default playlist, last 3 days)
#   yt 7                  → Run pipeline (default playlist, last 7 days)
#   yt --urls <URL1> ...  → Process specific video URLs
#   yt --dry-run          → Extract + analyze only, skip publish/Notion
#
# The pipeline runs on the DO droplet (aicos-droplet via Tailscale).
# Output streams in real time. Typical run: 3-4 min per new video.

DROPLET="aicos-droplet"
REMOTE_DIR="/opt/ai-cos-mcp"
RUNNER="uv run python -m runners.pipeline"

# Build remote command from arguments
ARGS=""

# Pass through --urls and --dry-run directly
if [ "$1" == "--urls" ] || [ "$1" == "--dry-run" ]; then
    ARGS="$@"
# Single numeric arg = --since-days N
elif [[ "$1" =~ ^[0-9]+$ ]]; then
    ARGS="--since-days $1"
# No args = defaults (3 days)
elif [ $# -eq 0 ]; then
    ARGS=""
else
    echo "Usage: yt [DAYS] [--urls URL1 URL2 ...] [--dry-run]"
    exit 1
fi

echo "Running pipeline on $DROPLET..."
echo "Command: $RUNNER $ARGS"
echo ""

ssh -t root@${DROPLET} "cd ${REMOTE_DIR} && ${RUNNER} ${ARGS}"
